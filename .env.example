TWITCH_BOT_USERNAME=your_bot_username
TWITCH_OAUTH_TOKEN=oauth:your_bot_oauth_token
TWITCH_CHANNEL=your_channel_name
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REFRESH_TOKEN=
TWITCH_TOKEN_STATE_PATH=.lupusaria-twitch-token.json
# Optional broadcaster token for ad schedule alerts. Must include channel:read:ads.
# Optional ads app credentials. Leave blank to use TWITCH_CLIENT_ID / TWITCH_CLIENT_SECRET.
TWITCH_ADS_CLIENT_ID=
TWITCH_ADS_CLIENT_SECRET=
TWITCH_ADS_OAUTH_TOKEN=
TWITCH_ADS_REFRESH_TOKEN=
TWITCH_ADS_TOKEN_STATE_PATH=.lupusaria-twitch-ads-token.json

# AI_PROVIDER can be mock, gemini, or openai-compatible.
AI_PROVIDER=mock
AI_API_KEY=
# OpenAI-compatible is mainly for local Ollama experiments.
AI_BASE_URL=http://localhost:11434/v1
# Required when AI_PROVIDER=openai-compatible. Leave blank for mock or Gemini.
AI_MODEL=
# Optional fallback provider, such as gemini, when the primary AI request fails.
AI_FALLBACK_PROVIDER=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_THINKING_LEVEL=high
AI_MAX_OUTPUT_TOKENS=1024
AI_MAX_RETRIES=3

BOT_NAME=LupusAria
STREAMER_NAME=your_streamer_name
STREAMER_PRONOUNS=they/them
BOT_PERSONALITY=Warm, steady, lightly playful, and useful. You fit into live Twitch chat without dominating it.
BOT_KNOWLEDGE_PATH=.lupusaria-knowledge.md
ENABLE_MENTION_RESPONSES=true
ENABLE_ASK_COMMAND=true
ENABLE_LURK_COMMAND=true
ENABLE_COMMANDS_COMMAND=true
ENABLE_RESET_COMMAND=true
MAX_CONTEXT_MESSAGES=30
STREAM_CONTEXT_TTL_SECONDS=120
# Crop Twitch stream thumbnails to the game capture before !game analyze.
# Values are percentages of the 1280x720 preview frame; these defaults match Ursa's OBS layout.
GAME_SNAPSHOT_CROP_ENABLED=true
GAME_SNAPSHOT_CROP_X=0.255
GAME_SNAPSHOT_CROP_Y=0.085
GAME_SNAPSHOT_CROP_WIDTH=0.73
GAME_SNAPSHOT_CROP_HEIGHT=0.73
GLOBAL_COOLDOWN_SECONDS=6
USER_COOLDOWN_SECONDS=20

AUTOSO_ENABLED=true
RECENT_STREAMER_MIN_WATCH_MINUTES=15
RECENT_STREAMER_RECENT_DAYS=14
RECENT_STREAMER_PAGE_SIZE=5
RECENT_STREAMER_SHOUTOUT_DELAY_SECONDS=2
RECENT_STREAMER_CACHE_HOURS=6
RECENT_STREAMER_CHATTERS_POLL_SECONDS=60

AD_ALERTS_ENABLED=false
AD_ALERT_WARNING_MINUTES=5
AD_ALERT_POLL_SECONDS=30
AD_ALERT_WARNING_MESSAGE=Heads up: ads are scheduled in about %s.
AD_ALERT_START_MESSAGE=Ad break starting now. Good moment to stretch, hydrate, and rest your eyes.
AD_ALERT_END_MESSAGE=Welcome back. Ads should be done now.

ANNOUNCEMENTS_ENABLED=false
# Local JSON file managed by the desktop app.
ANNOUNCEMENTS_PATH=.lupusaria-announcements.json
ANNOUNCEMENT_POLL_SECONDS=30

MONTHLY_AI_BUDGET_USD=5
DAILY_AI_BUDGET_USD=0.50
MAX_AI_REQUESTS_PER_HOUR=30
AI_BUDGET_STATE_PATH=.lupusaria-budget.json
CHAT_LOG_PATH=.lupusaria-chat.jsonl
