TWITCH_BOT_USERNAME=your_bot_username
TWITCH_OAUTH_TOKEN=oauth:your_bot_oauth_token
TWITCH_CHANNEL=your_channel_name
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REFRESH_TOKEN=
TWITCH_TOKEN_STATE_PATH=.lupusaria-twitch-token.json

# AI_PROVIDER can be mock, gemini, or openai-compatible.
AI_PROVIDER=mock
AI_API_KEY=
# Only used when AI_PROVIDER=openai-compatible.
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

BOT_NAME=LupusAria
BOT_PERSONALITY=Warm, grounded, lightly playful, and useful. You fit into live Twitch chat without dominating it.
MAX_CONTEXT_MESSAGES=30
GLOBAL_COOLDOWN_SECONDS=6
USER_COOLDOWN_SECONDS=20

MONTHLY_AI_BUDGET_USD=5
DAILY_AI_BUDGET_USD=0.50
MAX_AI_REQUESTS_PER_HOUR=30
AI_BUDGET_STATE_PATH=.lupusaria-budget.json
